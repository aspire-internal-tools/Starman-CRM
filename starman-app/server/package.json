{
  "name": "starman-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starman CRM API — Express + Prisma + PostgreSQL",
  "scripts": {
    "test": "node --test",
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "node prisma/seed.js",
    "setup": "prisma migrate deploy && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20"
  }
}
