# Copy to .env for local (non-Docker) runs. Docker Compose injects its own values.
DATABASE_URL="postgresql://starman:starman@localhost:5432/starman?schema=public"

# Auth — generate a long random secret for production (e.g. `openssl rand -base64 48`)
JWT_SECRET="dev-only-change-me-in-production"
JWT_EXPIRES_IN="12h"

PORT=4000
WEB_ORIGIN="http://localhost:4000"
NODE_ENV=development
TRUST_PROXY=false

# ---- AI Support (optional) ----
# Leave AI_PROVIDER=simulated (or blank AI_BASE_URL) for the free built-in answers.
# Pick ONE option to use a real model. Data is sent ONLY to the endpoint you set.
#
# Self-hosted (most private — data never leaves your machine; install Ollama, `ollama pull llama3.1`):
#   AI_PROVIDER=local
#   AI_BASE_URL=http://host.docker.internal:11434/v1
#   AI_MODEL=llama3.1
#
# Azure OpenAI (production requires a separately verified Canadian regional deployment):
#   AI_PROVIDER=azure
#   AI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
#   AI_KEY=your-azure-key
#   AI_MODEL=YOUR-DEPLOYMENT
#   AI_API_VERSION=2024-06-01
#   AI_DEPLOYMENT_TYPE=regional
#
# Direct OpenAI (local development only; rejected when NODE_ENV=production):
#   AI_PROVIDER=openai
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_KEY=sk-...
#   AI_MODEL=gpt-4o-mini
AI_PROVIDER=simulated
AI_BASE_URL=
AI_KEY=
AI_MODEL=gpt-4o-mini
AI_API_VERSION=2024-06-01
AI_DEPLOYMENT_TYPE=
